# ── Backend (services/api) ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:athena@localhost:5432/athena
REDIS_URL=redis://localhost:6379/0
SEARXNG_URL=http://localhost:8080

# Deployment environment. "dev" (default) keeps auth optional and secrets non-fatal.
# Set to "production" for any non-localhost deploy — this makes the next two REQUIRED (fatal if unset).
ATHENA_ENV=dev

# Fernet key for the API-key vault. REQUIRED in production (and recommended in dev so stored provider
# keys survive restarts). Generate one:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ATHENA_SECRET=

# Shared bearer token. Unset = open API (fine for localhost). REQUIRED in production: callers must send
# `Authorization: Bearer <token>`. The frontend reads it from localStorage key `athena:api_token`.
ATHENA_API_TOKEN=

# Comma-separated allowed CORS origins. Never set to "*" in production.
ATHENA_CORS_ORIGINS=http://localhost:3000

# Optional tuning:
# ATHENA_MAX_CONCURRENT_RUNS=3   # cap on simultaneous research runs (extras queue)
# ATHENA_JS_FETCH=false          # opt-in headless-browser fallback for JS pages (heavier; widens SSRF surface)

# ── Frontend (apps/web) ───────────────────────────────────────────────────
NEXT_PUBLIC_API=http://localhost:7000
