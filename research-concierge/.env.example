# Gemini model auth — use ONE of:
#   (a) AI Studio API key (simplest; works in Colab/Kaggle):
GOOGLE_API_KEY=
#   (b) Vertex AI / GCP: leave GOOGLE_API_KEY blank and authenticate with `gcloud auth application-default login`

# Optional: override the Gemini model the agents use
# ADK_MODEL=gemini-flash-latest

# ATHENA engine (the MCP server proxies to this backend)
ATHENA_API_URL=http://localhost:7000
# Only needed if the backend has ATHENA_API_TOKEN set (production):
ATHENA_API_TOKEN=
